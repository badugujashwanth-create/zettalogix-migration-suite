# Frontend-only browser configuration.
# Backend secrets belong in the external API or the hosting provider secret store.
VITE_API_BASE_URL=http://localhost:5206

# Google Picker frontend configuration.
# Do not put Google client secrets or refresh tokens in frontend env files.
VITE_GOOGLE_CLIENT_ID=your_browser_client_id
VITE_GOOGLE_API_KEY=your_browser_api_key
VITE_GOOGLE_APP_ID=your_cloud_project_number
VITE_GOOGLE_DRIVE_SCOPE=https://www.googleapis.com/auth/drive.readonly

# Supabase frontend configuration.
# Use the public project URL and publishable key, not database credentials.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key
