# Frontend-only browser configuration.
# Backend secrets belong in ZMS.API or the hosting provider secret store.
VITE_API_BASE_URL=http://localhost:5206

# Google Picker frontend configuration.
# VITE_GOOGLE_CLIENT_ID is safe for the frontend.
# VITE_GOOGLE_API_KEY is used by Google Picker.
# VITE_GOOGLE_APP_ID is the Google Cloud project number.
# Do not put Google client secrets or refresh tokens in frontend env files.
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_API_KEY=
VITE_GOOGLE_APP_ID=
VITE_GOOGLE_DRIVE_SCOPE=https://www.googleapis.com/auth/drive.readonly

# Supabase frontend configuration.
# Use the public project URL and publishable key, not database credentials.
VITE_SUPABASE_URL=https://hxptmbphcdyzhmwnimwh.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_wdNS0ihFvr9VhNYb4lSZCg_RyHV3ToW
